{
  "openapi": "3.1.0",
  "info": {
    "title": "FluxDown API",
    "description": "FluxDown 桌面应用的本机 HTTP API。仅监听 `127.0.0.1`（默认端口 17800，可在 设置 → API 服务 中修改）。\n\n- **takeover**（脚本接管）：油猴脚本提交下载，进入快速下载确认流程；需 `X-FluxDown-Client` 头\n- **aria2**：aria2 JSON-RPC 兼容垫片，「发送到 aria2」类脚本与 AriaNg 可直接对接\n- **management**（管理 API）：任务查询/创建/暂停/恢复/删除与队列查询，供 MCP/自动化客户端使用；强制要求 token（`Authorization: Bearer <token>` 或 `X-FluxDown-Token` 头）",
    "license": {
      "name": "MIT",
      "identifier": "MIT"
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:17800",
      "description": "本机 API 服务（默认端口）"
    }
  ],
  "paths": {
    "/api/v1/info": {
      "get": {
        "tags": [
          "management"
        ],
        "summary": "应用信息（名称与版本号）。",
        "operationId": "api_info",
        "responses": {
          "200": {
            "description": "应用信息",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiInfo"
                }
              }
            }
          },
          "401": {
            "description": "token 无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "403": {
            "description": "服务端未配置 token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "tokenHeader": []
          }
        ]
      }
    },
    "/api/v1/queues": {
      "get": {
        "tags": [
          "management"
        ],
        "summary": "列出全部命名队列。",
        "operationId": "api_list_queues",
        "responses": {
          "200": {
            "description": "队列列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/QueueDto"
                  }
                }
              }
            }
          },
          "401": {
            "description": "token 无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "tokenHeader": []
          }
        ]
      }
    },
    "/api/v1/tasks": {
      "get": {
        "tags": [
          "management"
        ],
        "summary": "列出全部任务，可按状态过滤。",
        "operationId": "api_list_tasks",
        "parameters": [
          {
            "name": "status",
            "in": "path",
            "description": "按状态过滤：0=pending, 1=downloading, 2=paused, 3=completed, 4=error, 5=preparing",
            "required": true,
            "schema": {
              "type": [
                "integer",
                "null"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "任务列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TaskDto"
                  }
                }
              }
            }
          },
          "401": {
            "description": "token 无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "tokenHeader": []
          }
        ]
      },
      "post": {
        "tags": [
          "management"
        ],
        "summary": "直接创建下载任务（不弹确认框），返回新任务 ID。",
        "operationId": "api_create_task",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatedTask"
                }
              }
            }
          },
          "400": {
            "description": "载荷非法或缺少 url",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "401": {
            "description": "token 无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "503": {
            "description": "应用关闭中",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "tokenHeader": []
          }
        ]
      }
    },
    "/api/v1/tasks/continue": {
      "put": {
        "tags": [
          "management"
        ],
        "summary": "恢复全部已暂停任务。",
        "operationId": "api_continue_all",
        "responses": {
          "200": {
            "description": "已全部恢复",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "401": {
            "description": "token 无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "tokenHeader": []
          }
        ]
      }
    },
    "/api/v1/tasks/pause": {
      "put": {
        "tags": [
          "management"
        ],
        "summary": "暂停全部活跃任务（pending / downloading / preparing）。",
        "operationId": "api_pause_all",
        "responses": {
          "200": {
            "description": "已全部暂停",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "401": {
            "description": "token 无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "tokenHeader": []
          }
        ]
      }
    },
    "/api/v1/tasks/{id}": {
      "get": {
        "tags": [
          "management"
        ],
        "summary": "按 ID 查询单个任务。",
        "operationId": "api_get_task",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "任务 ID（UUID）",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "任务信息",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskDto"
                }
              }
            }
          },
          "401": {
            "description": "token 无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "404": {
            "description": "任务不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "tokenHeader": []
          }
        ]
      },
      "delete": {
        "tags": [
          "management"
        ],
        "summary": "删除任务，可选同时删除磁盘文件。",
        "operationId": "api_delete_task",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "任务 ID（UUID）",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "deleteFiles",
            "in": "path",
            "description": "true = 同时删除磁盘文件。默认 false（仅删记录）。",
            "required": true,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "已删除",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "401": {
            "description": "token 无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "404": {
            "description": "任务不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "tokenHeader": []
          }
        ]
      }
    },
    "/api/v1/tasks/{id}/continue": {
      "put": {
        "tags": [
          "management"
        ],
        "summary": "恢复单个任务。",
        "operationId": "api_continue_task",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "任务 ID（UUID）",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "已恢复",
