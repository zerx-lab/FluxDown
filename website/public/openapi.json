              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "401": {
            "description": "token 无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "404": {
            "description": "任务不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "tokenHeader": []
          }
        ]
      }
    },
    "/api/v1/tasks/{id}/pause": {
      "put": {
        "tags": [
          "management"
        ],
        "summary": "暂停单个任务。",
        "operationId": "api_pause_task",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "任务 ID（UUID）",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "已暂停",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "401": {
            "description": "token 无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "404": {
            "description": "任务不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "tokenHeader": []
          }
        ]
      }
    },
    "/download": {
      "post": {
        "tags": [
          "takeover"
        ],
        "summary": "提交单个外部下载请求。用 `Bytes` 而非 `Json` 提取：油猴脚本可能不带\n`application/json` Content-Type（保留旧实现的宽容行为）。",
        "operationId": "takeover_download",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DownloadRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "已受理，进入快速下载确认流程",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "400": {
            "description": "载荷非法或缺少 url",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "401": {
            "description": "token 无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "403": {
            "description": "缺少 X-FluxDown-Client 头",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          }
        },
        "security": [
          {
            "tokenHeader": []
          }
        ]
      }
    },
    "/download/batch": {
      "post": {
        "tags": [
          "takeover"
        ],
        "summary": "批量提交外部下载请求。支持 `{\"urls\":[...]}` 与 `{\"items\":[{...}]}` 两种形态，\n合并为单次确认。鉴权与 `/download` 相同。",
        "operationId": "takeover_download_batch",
        "responses": {
          "200": {
            "description": "已受理",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "400": {
            "description": "载荷非法",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          }
        },
        "security": [
          {
            "tokenHeader": []
          }
        ]
      }
    },
    "/jsonrpc": {
      "post": {
        "tags": [
          "aria2"
        ],
        "summary": "aria2 客户端约定：HTTP 层始终 200，错误在 JSON-RPC envelope 内表达。",
        "operationId": "jsonrpc",
        "responses": {
          "200": {
            "description": "JSON-RPC 响应（错误在 envelope 内表达）。支持方法：aria2.addUri / aria2.getVersion / aria2.getGlobalStat / system.multicall / system.listMethods；token 可经 X-FluxDown-Token 头或 params[0]=\"token:xxx\" 传递"
          }
        },
        "security": [
          {
            "tokenHeader": []
          }
        ]
      }
    },
    "/mcp": {
      "post": {
        "tags": [
          "mcp"
        ],
        "summary": "MCP（Model Context Protocol）端点。强制 token 鉴权（Bearer /\nX-FluxDown-Token，复用管理 API 门禁）。请求返回 `200 application/json`\nJSON-RPC 响应；通知（无 `id`）返回 `202 Accepted` 空体。",
        "operationId": "mcp",
        "responses": {
          "200": {
            "description": "JSON-RPC 响应（initialize / tools/list / tools/call / ping）"
          },
          "202": {
            "description": "通知已接受（无响应体）"
          },
          "401": {
            "description": "token 无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          },
          "403": {
            "description": "服务端未配置 token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMessage"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "tokenHeader": []
          }
        ]
      }
    },
    "/ping": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "探活。返回应用名、版本号与 `pong`。无鉴权。",
        "operationId": "ping",
        "responses": {
          "200": {
            "description": "应用存活，返回 app/version/message"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiInfo": {
        "type": "object",
        "description": "应用信息（`GET /api/v1/info` 响应）。",
        "required": [
          "name",
          "version"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "CreateTaskRequest": {
        "type": "object",
        "description": "创建任务请求（`POST /api/v1/tasks`）。\n\n与外部下载请求 [`DownloadRequest`] 不同：本请求**直接创建任务**，\n不经过快速下载确认弹框（管理 API 的调用方是受信任的自动化客户端）。\n\n# Examples\n\n```\nuse fluxdown_api::types::CreateTaskRequest;\n\nlet req: CreateTaskRequest =\n    serde_json::from_str(r#\"{\"url\":\"https://example.com/f.zip\",\"segments\":8}\"#).unwrap();\nassert_eq!(req.url, \"https://example.com/f.zip\");\nassert_eq!(req.segments, 8);\nassert!(req.save_dir.is_empty()); // 空 = 使用全局默认保存目录\n```",
        "required": [
          "url"
        ],
        "properties": {
          "checksum": {
            "type": "string",
            "description": "Checksum spec，格式 `algo=hexhash`（空 = 跳过校验）。"
          },
          "cookies": {
            "type": "string"
          },
          "fileName": {
            "type": "string",
            "description": "空 = 从 URL / Content-Disposition 推断。"
          },
          "headers": {
            "type": [
              "object",
              "null"
            ],
            "description": "附加 HTTP 请求头。",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "proxyUrl": {
            "type": "string",
            "description": "单任务代理 URL（空 = 使用全局代理）。"
          },
          "queueId": {
            "type": "string",
            "description": "命名队列 ID（空 = 默认队列）。"
          },
          "referrer": {
            "type": "string"
          },
          "saveDir": {
            "type": "string",
            "description": "空 = 使用全局默认保存目录。"
          },
          "segments": {
            "type": "integer",
            "format": "int32",
            "description": "0 = 由 segment_advisor 按文件大小动态决定。"
          },
          "torrentB64": {
            "type": [
              "string",
              "null"
            ],
            "description": "BT 种子文件字节（base64 编码，aria2 `addTorrent` 兼容入口）。\n非空时按种子任务创建，`url` 允许为空占位。"
          },
          "url": {
            "type": "string"
          },
          "userAgent": {
            "type": "string",
            "description": "空 = 使用全局 User-Agent。"
          }
        }
      },
      "CreatedTask": {
        "type": "object",
        "description": "创建任务响应（`POST /api/v1/tasks`）。",
        "required": [
          "taskId"
        ],
        "properties": {
          "taskId": {
            "type": "string"
          }
        }
      },
      "DownloadRequest": {
        "type": "object",
        "description": "外部下载请求载荷（浏览器扩展 / 油猴脚本 / aria2 兼容层）。\n\n由宿主的「外部下载」通道消费：缓存请求事务 → 弹出快速下载确认框 →\n用户确认后创建任务。与管理 API 的 [`CreateTaskRequest`]（直接建任务、\n无确认框）语义不同。\n\n# Examples\n\n```\nuse fluxdown_api::types::DownloadRequest;\n\nlet req: DownloadRequest =\n    serde_json::from_str(r#\"{\"url\":\"https://example.com/f.zip\"}\"#).unwrap();\nassert_eq!(req.url, \"https://example.com/f.zip\");\nassert!(req.filename.is_empty());\n```",
        "required": [
          "url"
        ],
        "properties": {
          "audioUrl": {
            "type": [
              "string",
              "null"
            ],
            "description": "音频轨 URL（可选，通用「视频轨+音频轨」离散下载对语义，按 MIME\nvideo/* vs audio/* 分轨判定，非站点专用协议字段）。\n非空 = 这是一对轨道，引擎分别下载两路后用 ffmpeg mux 合并；\n空/缺省 = 普通单 URL 下载。"
          },
          "body": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/RequestBody",
                "description": "浏览器原始请求体（仅在非 GET 时有意义）。"
              }
            ]
          },
          "cookies": {
            "type": "string"
          },
          "fileSize": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "文件大小提示（字节）。\n  - `>0` = 已知大小，跳过 probe\n  - `-1` = 大小未知但确认是下载资源（webRequest 嗅探），跳过 probe\n  - `0` / `None` = 正常 probe"
          },
          "filename": {
            "type": "string"
          },
          "headers": {
            "type": [
              "object",
              "null"
            ],
            "description": "浏览器请求中捕获的额外 HTTP 头（如 Authorization）。\n由下载引擎在发起请求时附加到请求头中。",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
