---
/**
 * 默认首页(/)——hreflang x-default 语言选择页(英文内容,客户端跟随浏览器语言)。
 * SEO 变体:/zh/、/ja/ 为 SSR 固定语言页,三页经 HOME_ALTERNATES 双向互指。
 * 谷歌规范:不做基于语言的自动重定向;客户端仅同步展示层(标签页标题/描述)。
 */
import Layout from "../layouts/Layout.astro";
import HomeMain from "../components/HomeMain.astro";
import { HOME_META, HOME_ALTERNATES } from "../lib/seo";

const localizedMeta = {
  zh: HOME_META.zh,
  ja: HOME_META.ja,
};
---

<Layout
  title={HOME_META.en.title}
  description={HOME_META.en.description}
  alternates={HOME_ALTERNATES}
>
  <HomeMain />
  <!-- 标签页标题/描述跟随客户端语言(仅展示层;抓取快照仍是英文 x-default) -->
  <script is:inline define:vars={{ localizedMeta }}>
    (function () {
      function apply(loc) {
        var meta = localizedMeta[loc];
        if (!meta) return;
        document.title = meta.title;
        var d = document.querySelector('meta[name="description"]');
        if (d) d.setAttribute("content", meta.description);
      }
      var loc = null;
      try { loc = localStorage.getItem("fluxdown-locale"); } catch (e) {}
      if (!loc) {
        var langs = navigator.languages || [navigator.language];
        for (var i = 0; i < langs.length; i++) {
          var l = (langs[i] || "").toLowerCase();
          if (l.indexOf("zh") === 0) { loc = "zh"; break; }
          if (l.indexOf("ja") === 0) { loc = "ja"; break; }
          if (l.indexOf("en") === 0) break;
        }
      }
      if (loc) apply(loc);
      window.addEventListener("locale-change", function (e) {
        if (e.detail && e.detail.locale) apply(e.detail.locale);
      });
    })();
  </script>
</Layout>
