---
/**
 * 文档正文页(全部静态预渲染)。
 * 路由规则(设计决策 D3/D4):以 en 集合为 slug 全集 × {en, zh};
 * zh 缺译 → 渲染 en 内容 + 未翻译横幅 + noindex,不参与 hreflang/sitemap。
 */
import { getCollection, render } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import { FloatingNavbar } from "../../../components/ui/floating-navbar";
import Footer from "../../../components/Footer";
import DocsSidebar from "../../../components/docs/DocsSidebar.astro";
import DocsPageNav from "../../../components/docs/DocsPageNav.astro";
import DocsToc from "../../../components/docs/DocsToc";
import DocsFeedbackForm from "../../../components/docs/DocsFeedbackForm";
import DocsSearch from "../../../components/docs/DocsSearch";
import { buildDocsNav, type DocsLang } from "../../../lib/docs-nav";
import { getFallbackSlugs } from "../../../lib/docs-fallback";
import { docsSourceHash } from "../../../lib/docs-hash";

export const prerender = true;

export async function getStaticPaths() {
  const all = await getCollection("docs");
  const en = all.filter((e) => e.id.startsWith("en/"));
  const zhMap = new Map(
    all.filter((e) => e.id.startsWith("zh/")).map((e) => [e.id.slice(3), e]),
  );
  // 回退判定与 sitemap filter 共用单一来源(docs-fallback.ts)
  const fallbackSlugs = getFallbackSlugs();

  const paths = [];
  for (const e of en) {
    const slug = e.id.slice(3);
    const enHash = docsSourceHash(e.body ?? "");
    const zh = zhMap.get(slug);
    const hasZh = zh !== undefined && !fallbackSlugs.has(slug);

    paths.push({
      params: { lang: "en", slug },
      props: { entry: e, slugPath: slug, fallback: false, stale: false, hasZh },
    });

    if (hasZh) {
      // sourceHash 缺失视为"新鲜度未知",不显示过期横幅(D5)
      const stale = zh.data.sourceHash !== undefined && zh.data.sourceHash !== enHash;
      paths.push({
        params: { lang: "zh", slug },
        props: { entry: zh, slugPath: slug, fallback: false, stale, hasZh: true },
      });
    } else {
      paths.push({
        params: { lang: "zh", slug },
        props: { entry: e, slugPath: slug, fallback: true, stale: false, hasZh: false },
      });
    }
  }
  return paths;
}

const { entry, slugPath, fallback, stale, hasZh } = Astro.props;
const lang = Astro.params.lang as DocsLang;
const zh = lang === "zh";

const all = await getCollection("docs");
const { groups, flat } = buildDocsNav(all, lang);
const { Content, headings } = await render(entry);

const site = Astro.site ?? new URL("https://fluxdown.zerx.dev");
const enUrl = new URL(`/docs/en/${slugPath}/`, site).href;
const zhUrl = new URL(`/docs/zh/${slugPath}/`, site).href;
// hreflang(D4):仅当 zh 真实存在译文时互链;回退页自身不输出任何 alternate
const alternates = fallback
  ? []
  : hasZh
    ? [
        { lang: "en", href: enUrl },
        { lang: "zh", href: zhUrl },
        { lang: "x-default", href: enUrl },
      ]
    : [
        { lang: "en", href: enUrl },
        { lang: "x-default", href: enUrl },
      ];

const idx = flat.findIndex((i) => i.slug === slugPath);
const prev = idx > 0 ? (flat[idx - 1] ?? null) : null;
const next = idx >= 0 && idx < flat.length - 1 ? (flat[idx + 1] ?? null) : null;

const REPO = "https://github.com/zerx-lab/fluxdown";
const srcLang = fallback ? "en" : lang;
const filePath = `website/src/content/docs/${srcLang}/${slugPath}.md`;
const editUrl = `${REPO}/edit/main/${filePath}`;
const historyUrl = `${REPO}/commits/main/${filePath}`;
// GitHub /new?filename= 会忽略 URL 路径末级目录(isaacs#1527),目录必须拼进 filename
const translateUrl = fallback
  ? `${REPO}/new/main/website/src/content/docs/zh?filename=${encodeURIComponent(`${slugPath}.md`)}`
  : undefined;

const pagePath = `/docs/${lang}/${slugPath}/`;
const altHref = zh ? `/docs/en/${slugPath}/` : `/docs/zh/${slugPath}/`;
const sectionLabel = groups.find((g) => g.id === entry.data.section)?.label;
---

<Layout
  title={`${entry.data.title} - FluxDown Docs`}
  description={entry.data.description ??
    (zh ? "FluxDown 使用文档。" : "FluxDown documentation.")}
  canonicalUrl={zh ? zhUrl : enUrl}
  lang={zh ? "zh-CN" : "en"}
  ogLocale={zh ? "zh_CN" : "en_US"}
  alternates={alternates}
  noindex={fallback}
>
  <FloatingNavbar client:load />
  <main class="relative mx-auto max-w-7xl px-4 pt-28 pb-16 sm:px-6 lg:px-8">
    <!-- 氛围光斑(与索引页/营销站一致的背景层) -->
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute left-1/3 top-0 h-[260px] w-[520px] -translate-x-1/2 rounded-full bg-brand-sky/[0.04] blur-[110px]"></div>
    </div>
    <div
      class="lg:grid lg:grid-cols-[240px_minmax(0,1fr)] lg:gap-10 xl:grid-cols-[240px_minmax(0,1fr)_200px]"
    >
      <!-- 桌面侧边栏(≥lg) -->
      <aside class="hidden lg:block lg:border-r lg:border-dark-border/50">
        <div class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto pr-5">
          <DocsSearch client:idle lang={lang} />
          <DocsSidebar groups={groups} currentPath={Astro.url.pathname} lang={lang} />
        </div>
      </aside>

      <div class="min-w-0">
        <!-- 移动端目录:原生 details 折叠,零 JS,不与 navbar 汉堡竞争入口(A5) -->
        <details class="mb-6 rounded-xl border border-dark-border bg-dark-surface1/70 backdrop-blur-sm lg:hidden">
          <summary
            class="cursor-pointer select-none px-4 py-2.5 text-sm font-medium text-dark-text-secondary"
          >
            {zh ? "文档目录" : "Docs menu"}
          </summary>
          <div class="border-t border-dark-border p-4">
            <DocsSearch client:idle lang={lang} />
            <DocsSidebar groups={groups} currentPath={Astro.url.pathname} lang={lang} />
          </div>
        </details>

        <!-- locale 纠偏提示(D6):cookie 被拦截但 localStorage 可用时的兜底 -->
        <div
          id="docs-locale-hint"
          hidden
          class="mb-4 rounded-xl border border-brand-sky/25 bg-brand-sky/5 px-4 py-2.5 text-sm text-dark-text-secondary backdrop-blur-sm"
        >
          <a id="docs-locale-hint-link" href={altHref} class="text-brand-sky hover:underline"></a>
        </div>

        {
          fallback && (
            <div class="mb-6 rounded-xl border border-warning/30 bg-warning/5 px-4 py-3 text-sm text-dark-text-secondary backdrop-blur-sm">
              {zh
                ? "此页尚未翻译为中文,以下为英文内容。"
                : "This page has not been translated yet."}
              <a
                href={translateUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="ml-1 text-brand-sky hover:underline"
              >
                {zh ? "帮我们翻译 →" : "Help us translate →"}
              </a>
            </div>
          )
        }
        {
          stale && (
            <div class="mb-6 rounded-xl border border-warning/30 bg-warning/5 px-4 py-3 text-sm text-dark-text-secondary backdrop-blur-sm">
              {zh
                ? "此译文可能落后于英文版本。"
                : "This translation may be out of date."}
              <a
                href={editUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="ml-1 text-brand-sky hover:underline"
              >
                {zh ? "帮我们更新 →" : "Help us update →"}
              </a>
            </div>
          )
        }

        <article class="min-w-0">
          {
            sectionLabel && (
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-sky">
                {sectionLabel}
              </p>
            )
          }
          <h1 class="mt-2 text-3xl font-bold tracking-tight text-dark-text sm:text-4xl">
            {entry.data.title}
          </h1>
          {
            entry.data.description && (
              <p class="mt-3 text-base leading-relaxed text-dark-text-secondary">
                {entry.data.description}
              </p>
            )
          }
          <div class="docs-prose mt-8">
            <Content />
          </div>
        </article>

        <DocsPageNav
          prev={prev}
          next={next}
          editUrl={editUrl}
          historyUrl={historyUrl}
          translateUrl={translateUrl}
          lang={lang}
        />
        <DocsFeedbackForm client:visible pagePath={pagePath} lang={lang} />
      </div>

      <!-- 右侧目录(≥xl) -->
      <aside class="hidden xl:block">
        <div class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto">
          <DocsToc client:idle headings={headings} lang={lang} />
        </div>
      </aside>
    </div>
  </main>
  <Footer client:load />

  <script is:inline define:vars={{ pageLang: lang, altHref }}>
    // 1) 语言纠偏提示:localStorage 与 URL 语言不一致时显示切换提示(不自动跳转,防循环)
    try {
      var saved = localStorage.getItem("fluxdown-locale");
      if (saved && saved !== pageLang) {
        var hint = document.getElementById("docs-locale-hint");
        var link = document.getElementById("docs-locale-hint-link");
        if (hint && link) {
          link.textContent = saved === "zh" ? "查看此页中文版 →" : "View this page in English →";
          hint.hidden = false;
        }
      }
    } catch (e) {}

    // 2) navbar 语言切换在 docs 下改为路由跳转(设计决策 B2)
    window.addEventListener("locale-change", function (e) {
      var target = e.detail && e.detail.locale;
      if (target && target !== pageLang) {
        location.href = altHref;
      }
    });
  </script>
</Layout>
